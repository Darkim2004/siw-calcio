# Docker Compose database settings
POSTGRES_DB=calcio
POSTGRES_USER=calcio
POSTGRES_PASSWORD=change-me-postgres-password

# Seeded admin user
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=change-me-admin-password

# Azure Blob Storage, used with SPRING_PROFILES_ACTIVE=prod
AZURE_STORAGE_CONNECTION_STRING=change-me-azure-storage-connection-string
AZURE_STORAGE_CONTAINER_NAME=images

# Azure App Service / production profile
SPRING_PROFILES_ACTIVE=prod
